{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://profinaut.local/contracts/observability/capabilities.schema.json",
  "title": "Capabilities Response v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "features", "correlation"],
  "properties": {
    "schema_version": { "type": "string", "const": "obs.capabilities.v1" },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "state"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 128 },
          "state": { "type": "string", "enum": ["ENABLED", "DISABLED", "DEGRADED", "NOT_IMPLEMENTED"] },
          "reasons": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["code", "message"],
              "properties": {
                "code": { "type": "string", "minLength": 1, "maxLength": 64 },
                "message": { "type": "string", "minLength": 1, "maxLength": 512 },
                "since": { "type": "string", "format": "date-time" }
              }
            }
          }
        }
      }
    },
    "correlation": { "$ref": "correlation.schema.json" }
  }
}
