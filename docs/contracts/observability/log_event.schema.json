{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://profinaut.local/contracts/observability/log_event.schema.json",
  "title": "Structured Log Event v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "timestamp",
    "level",
    "message",
    "component",
    "trace_id",
    "run_id"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "obs.log_event.v1" },
    "timestamp": { "type": "string", "format": "date-time" },
    "level": { "type": "string", "enum": ["DEBUG", "INFO", "WARN", "ERROR", "CRITICAL"] },
    "message": { "type": "string", "minLength": 1, "maxLength": 2048 },
    "component": { "type": "string", "minLength": 1, "maxLength": 128 },
    "source": { "type": "string", "minLength": 1, "maxLength": 128 },
    "logger_name": { "type": "string", "minLength": 1, "maxLength": 256 },
    "trace_id": { "type": "string", "minLength": 8, "maxLength": 128 },
    "run_id": { "type": "string", "minLength": 8, "maxLength": 128 },
    "request_id": { "type": "string", "minLength": 8, "maxLength": 128 },
    "event_id": { "type": "string", "minLength": 8, "maxLength": 128 },
    "op": { "type": "string", "minLength": 1, "maxLength": 64 },
    "error_code": { "type": "string", "minLength": 1, "maxLength": 128 },
    "reason_code": { "type": "string", "minLength": 1, "maxLength": 128 },
    "fields": { "type": "object" }
  }
}
