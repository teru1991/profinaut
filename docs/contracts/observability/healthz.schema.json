{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://profinaut.local/contracts/observability/healthz.schema.json",
  "title": "Healthz Response v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "checks", "correlation"],
  "properties": {
    "schema_version": { "type": "string", "const": "obs.healthz.v1" },
    "status": { "type": "string", "enum": ["OK", "DEGRADED", "FAILED", "UNKNOWN"] },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "reason_code", "summary", "observed_at"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 128 },
          "status": { "type": "string", "enum": ["OK", "DEGRADED", "FAILED", "UNKNOWN"] },
          "reason_code": { "type": "string", "minLength": 1, "maxLength": 64 },
          "summary": { "type": "string", "minLength": 1, "maxLength": 512 },
          "observed_at": { "type": "string", "format": "date-time" },
          "details": { "type": "object" }
        }
      }
    },
    "correlation": { "$ref": "correlation.schema.json" }
  }
}
