{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "contracts/schemas/common/error_envelope.schema.json",
  "title": "ErrorEnvelope",
  "type": "object",
  "description": "Canonical standard error envelope for platform services.",
  "additionalProperties": true,
  "required": ["error"],
  "properties": {
    "error": {
      "type": "object",
      "description": "Canonical error object.",
      "additionalProperties": true,
      "required": ["code", "reason_code", "kind", "severity", "retryable", "source", "context"],
      "properties": {
        "code": { "type": "string", "minLength": 1, "description": "Stable logical error category." },
        "reason_code": { "type": "string", "minLength": 1, "description": "Concrete reason identifier." },
        "kind": {
          "type": "string",
          "enum": [
            "validation_error",
            "client_error",
            "auth_error",
            "permission_error",
            "conflict_error",
            "rate_limit_error",
            "dependency_error",
            "timeout_error",
            "internal_error",
            "unavailable_error"
          ]
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warn", "error", "critical"]
        },
        "retryable": { "type": "boolean" },
        "source": { "type": "string", "minLength": 1 },
        "message": { "type": "string" },
        "details": {},
        "schema_version": { "type": "string" },
        "contract_version": { "type": "string" },
        "context": {
          "type": "object",
          "additionalProperties": true,
          "required": ["component"],
          "properties": {
            "component": { "type": "string", "minLength": 1 },
            "request_id": { "type": "string" },
            "trace_id": { "type": "string" },
            "run_id": { "type": "string" },
            "path": { "type": "string" },
            "method": { "type": "string" },
            "status_code": { "type": "integer" },
            "upstream": { "type": "string" },
            "retry_after_ms": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
