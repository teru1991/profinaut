{
  "version": 2,
  "required_paths": [
    "metadata",
    "ssot",
    "transport",
    "hub",
    "wal",
    "errors",
    "manifest",
    "manifest.diag_semver",
    "manifest.coverage_hash",
    "manifest.coverage_v2_hash",
    "manifest.ws_rules_hash",
    "manifest.catalog_hash",
    "manifest.policy_hash",
    "manifest.symbol_meta_hash",
    "manifest.execution_surface_hash",
    "manifest.runtime_capability_hash"
  ],
  "deny_patterns": [
    "AKIA",
    "BEGIN PRIVATE KEY",
    "Authorization: Bearer ",
    "X-Api-Key",
    "SECRET",
    "TOKEN",
    "API_KEY",
    "api_key",
    "api_secret"
  ]
}
